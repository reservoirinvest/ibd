# Zerodha Kite Connect credentials (https://kite.trade/)
# Copy to .env and fill in. Leave OFFLINE=true in config to run without these.

KITE_API_KEY=your_api_key
KITE_API_SECRET=your_api_secret
# Access token is generated daily via the login flow (see README "Going live").
KITE_ACCESS_TOKEN=
KITE_USER_ID=your_zerodha_client_id

# Optional Ask AI providers (install with: uv pip install -e ".[ai]")
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
